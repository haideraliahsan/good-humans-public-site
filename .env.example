# ─── EmailJS (contact form) ─────────────────────────────────────────
# Sign in at https://www.emailjs.com — free tier = 200 emails/month.
#
# 1. Add an "Email Service" (Gmail, Outlook, Custom SMTP, etc.) — copy its Service ID here.
# 2. Add an "Email Template" that references {{name}} {{email}} {{company}}
#    {{interested_in}} {{message}} — or the single {{full_message}} — placeholders.
#    Copy its Template ID here.
# 3. Copy your Public Key from Account → API Keys.
# 4. Under Account → Domains, whitelist your production origins (e.g.
#    goodhumans.co, staging.goodhumans.co, localhost:3000 for local dev).
#
# All three vars are prefixed NEXT_PUBLIC_ because they're read on the client.
# That's the intended threat model for EmailJS — the Public Key is safe to
# expose; abuse is prevented by the domain whitelist above.

NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_xxxxxxx
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=template_xxxxxxx
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxxxxxx

# ─── Video Studio auth gate (optional) ──────────────────────────────
# When set, /video-generation prompts for this password once per tab.
# Leave empty in dev so the gate falls open automatically.

NEXT_PUBLIC_VIDEO_GEN_PASSWORD=
